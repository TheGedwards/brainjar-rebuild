# Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # server only, never NEXT_PUBLIC_

# /admin auth is now Supabase Auth (per-user accounts + roles in public.profiles).
# No admin env vars needed — users are created in the CMS. The old ADMIN_USER /
# ADMIN_PASSWORD Basic-auth vars are no longer read and can be removed.

# Contact form
CONTACT_TO_EMAIL=hello@brainjarmedia.com
RESEND_API_KEY=                          # optional; if blank, submissions are stored in Supabase only

NEXT_PUBLIC_SITE_URL=https://www.brainjarmedia.com
